# Supabase
# DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# DATABASE_SSL=true

# 로컬 PostgreSQL (docker compose up -d db 사용 시)
DATABASE_URL=postgresql+asyncpg://adoptai:adoptai@localhost:5432/adoptai
DATABASE_SSL=false

SECRET_KEY=change-me-in-production-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=86400
REFRESH_TOKEN_EXPIRE_DAYS=30
COOKIE_SECURE=false

LOCAL_UPLOAD_DIR=/var/lib/adoptai/uploads
MAX_IMAGE_UPLOAD_BYTES=10485760
CORS_ORIGINS=http://localhost:3000

# Supabase Storage (S3 호환) — 아래 3개가 모두 채워지면 업로드가 S3로 가고,
# 비어 있으면 LOCAL_UPLOAD_DIR + /static 서빙으로 폴백한다.
# 키는 대시보드 Storage → S3 Access Keys에서 발급 (anon/service key 아님).
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# 사진은 공고에 실려 공개되므로 public 버킷을 쓴다 (URL 만료 없음).
S3_BUCKET=adoptai-uploads
# Supabase 프로젝트 리전과 반드시 일치해야 서명이 통과한다.
S3_REGION=ap-northeast-2
# public URL(.../object/public/...) 생성용
SUPABASE_URL=

# Internal STT service
# 로컬 직접 실행: http://localhost:8001 / docker compose full: http://stt:8000
STT_BASE_URL=http://stt:8000
STT_TIMEOUT_SECONDS=180
STT_INTERNAL_API_KEY=
MAX_AUDIO_UPLOAD_BYTES=26214400
MAX_AUDIO_DURATION_SECONDS=300
REDIS_URL=redis://redis:6379/0

# 대표사진 선택 모델 (../VISION 에서 python build_final_model.py 실행 후 생성됨)
VISION_BASE_URL=http://vision:8000
VISION_TIMEOUT_SECONDS=180

# ── 비밀번호 재설정 메일 ────────────────────────────────────────────────
# 재설정 링크가 가리킬 프론트 주소
FRONTEND_BASE_URL=http://localhost:3000
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
# SMTP_HOST가 비면 메일을 보내지 않고 재설정 링크를 서버 로그에 남긴다(로컬 개발).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true
SMTP_TIMEOUT_SECONDS=10
MAIL_FROM=AdoptAI <no-reply@adoptai.local>

# ── 소셜 로그인 (카카오·구글) ───────────────────────────────────────────
# 콘솔에 등록할 redirect URI:
#   <OAUTH_CALLBACK_BASE_URL>/api/v1/auth/oauth/google/callback
#   <OAUTH_CALLBACK_BASE_URL>/api/v1/auth/oauth/kakao/callback
OAUTH_CALLBACK_BASE_URL=http://localhost:8000
OAUTH_TIMEOUT_SECONDS=10
# client id가 비어 있으면 해당 provider는 비활성(버튼도 노출하지 않음)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 카카오는 REST API 키. Client Secret을 끄면 KAKAO_CLIENT_SECRET은 비워도 된다.
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
